CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/PayUIndia-3DS2-SDK" "${PODS_ROOT}/PayUIndia-3DS2Core-SDK" "${PODS_ROOT}/PayUIndia-Analytics" "${PODS_ROOT}/PayUIndia-CrashReporter" "${PODS_ROOT}/PayUIndia-NetworkReachability" "${PODS_ROOT}/PayUIndia-TridentityMFA-SDK" "${PODS_XCFRAMEWORKS_BUILD_DIR}/PayUIndia-3DS2-SDK" "${PODS_XCFRAMEWORKS_BUILD_DIR}/PayUIndia-3DS2Core-SDK" "${PODS_XCFRAMEWORKS_BUILD_DIR}/PayUIndia-Analytics" "${PODS_XCFRAMEWORKS_BUILD_DIR}/PayUIndia-CrashReporter" "${PODS_XCFRAMEWORKS_BUILD_DIR}/PayUIndia-NetworkReachability" "${PODS_XCFRAMEWORKS_BUILD_DIR}/PayUIndia-TridentityMFA-SDK"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
OTHER_LDFLAGS = $(inherited) -framework "PayU3DS2CoreKit" -framework "PayU3DS2Kit" -framework "PayUAnalyticsKit" -framework "PayUCrashReporter" -framework "PayUNetworkReachability" -framework "PayUTridentityMFAKit" -framework "PayUliboqs"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/PayUIndia-3DS2-SDK" "-F${PODS_CONFIGURATION_BUILD_DIR}/PayUIndia-3DS2Core-SDK" "-F${PODS_CONFIGURATION_BUILD_DIR}/PayUIndia-Analytics" "-F${PODS_CONFIGURATION_BUILD_DIR}/PayUIndia-CrashReporter" "-F${PODS_CONFIGURATION_BUILD_DIR}/PayUIndia-NetworkReachability" "-F${PODS_CONFIGURATION_BUILD_DIR}/PayUIndia-TridentityMFA-SDK"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
